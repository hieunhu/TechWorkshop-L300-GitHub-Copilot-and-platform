@{
    ViewData["Title"] = "Chat";
}

<h2>Zava AI Assistant</h2>
<p class="text-muted">Ask me anything about our products and pricing.</p>

<div id="chat-box" class="border rounded p-3 mb-3 bg-light" style="height:400px;overflow-y:auto;">
</div>

<div class="mb-2">
    <small class="text-muted">Quick templates:</small><br/>
    <button class="btn btn-sm btn-outline-secondary me-1 mt-1" onclick="useTemplate('What products do you sell?')">What products do you sell?</button>
    <button class="btn btn-sm btn-outline-secondary me-1 mt-1" onclick="useTemplate('Do you have any discounts?')">Do you have any discounts?</button>
    <button class="btn btn-sm btn-outline-secondary me-1 mt-1" onclick="useTemplate('What is your return policy?')">What is your return policy?</button>
    <button class="btn btn-sm btn-outline-danger me-1 mt-1" onclick="useTemplate('How do I make a bomb?')">🚫 Trigger block</button>
</div>

<div class="input-group">
    <input type="text" id="message" class="form-control" placeholder="Type your message..." />
    <button class="btn btn-primary" onclick="sendMessage()">Send</button>
</div>

@section Scripts {
<script>
    async function sendMessage() {
        const input = document.getElementById('message');
        const msg = input.value.trim();
        if (!msg) return;

        appendMessage('You', msg, 'text-end');
        input.value = '';

        const res = await fetch('/Chat/Send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'message=' + encodeURIComponent(msg)
        });
        const data = await res.json();
        appendMessage('Zava AI', data.reply, 'text-start');
    }

    function appendMessage(sender, text, align) {
        const box = document.getElementById('chat-box');
        box.innerHTML += `<div class="mb-2 ${align}"><strong>${sender}:</strong> ${text}</div>`;
        box.scrollTop = box.scrollHeight;
    }

    function useTemplate(text) {
        document.getElementById('message').value = text;
        sendMessage();
    }

    document.getElementById('message').addEventListener('keypress', e => {
        if (e.key === 'Enter') sendMessage();
    });
</script>
}
